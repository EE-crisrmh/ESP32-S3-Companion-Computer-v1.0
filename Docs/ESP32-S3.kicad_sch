	(text_box "ESP32-S3-WROOM-1x\n\nIO35 - IO37 are not connected to the OSPI PSRAM and are not available for other users.\nNote: ESP32-S3 has four strapping pins: IO0, IO3, IO45, and IO46. \n\nIO0, IO45, and IO46. are connected to the chip's internal weak pull-up/pull-down during \nchip reset. \n\nIO3 is floating by default.  "
		(exclude_from_sim no)
		(at 255.27 12.7 0)
		(size 29.845 38.1)
		(margins 0.9525 0.9525 0.9525 0.9525)
